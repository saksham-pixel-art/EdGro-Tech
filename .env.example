# ─────────────────────────────────────────────────────────────────
# DATABASE SECRETS
# ─────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=replace-with-secure-64-char-string
DB_NAME=edgro_prod
DB_USER=edgro_app
DB_PASS=replace-with-secure-64-char-string

# ─────────────────────────────────────────────────────────────────
# APPLICATION SECRETS
# ─────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=replace-with-highly-entropic-256-bit-hmac-or-rsa-key
CORS_ORIGINS=https://www.edgrotech.com

# ─────────────────────────────────────────────────────────────────
# EXTERNAL INTEGRATIONS
# ─────────────────────────────────────────────────────────────────
GOOGLE_SA_KEY_PATH=/etc/secrets/google-sa.json
GOOGLE_SHEETS_ENABLED=true
GOOGLE_SHEETS_SPREADSHEET_ID=your-sheet-id
GOOGLE_SHEETS_SHEET_NAME=Leads

# ─────────────────────────────────────────────────────────────────
# FRONTEND VARIABLES
# ─────────────────────────────────────────────────────────────────
VITE_API_URL=https://api.edgrotech.com

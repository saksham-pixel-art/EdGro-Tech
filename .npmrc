# ─── npm configuration for cross-platform Cloudflare builds ───────────────────
#
# CRITICAL: Forces npm to install ALL optional dependencies including
# platform-specific native binaries needed on Cloudflare's Linux environment.
#
# Fixes:
#   - @rollup/rollup-linux-x64-gnu (Vite/Rollup native binary)
#   - lightningcss-linux-x64-gnu   (Tailwind CSS v4 / Vite CSS optimizer)
#   - lightningcss-linux-x64-musl  (Alpine Linux variant used by some CF workers)

include=optional
legacy-peer-deps=true

# Backend environment variables
# Copy to .env and fill in real values. Never commit this file.

SPRING_PROFILES_ACTIVE=prod

# Database
DATABASE_URL=jdbc:mysql://your-db-host:3306/edgro_prod?useSSL=true&serverTimezone=UTC
DB_USER=edgro_prod_user
DB_PASS=your_strong_password_here

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=your-256-bit-or-longer-secret-key-here
JWT_EXPIRATION_MS=86400000

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://edgrotech.com,https://www.edgrotech.com

# ── Google Sheets Integration ─────────────────────────────────────────────────
# Set GOOGLE_SHEETS_ENABLED=true to activate real-time lead sync to Google Sheets.
# Steps:
#   1. Create a GCP project → enable "Google Sheets API"
#   2. Create a Service Account → download the JSON key file
#   3. Share your Google Sheet with the service account email (Editor role)
#   4. Set GOOGLE_SA_KEY_PATH to the absolute path of the downloaded JSON key file
#   5. Set GOOGLE_SHEETS_SPREADSHEET_ID to the ID from your sheet URL:
#      https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
#   6. Set GOOGLE_SHEETS_SHEET_NAME to the tab name (default: Leads)

GOOGLE_SHEETS_ENABLED=false
GOOGLE_SA_KEY_PATH=/etc/secrets/edgro-sa-key.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_SHEET_NAME=Leads

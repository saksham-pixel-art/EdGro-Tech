<?xml version="1.0" encoding="UTF-8"?>
<!--
  Force all log output to stdout so Render/Docker captures it.
  Without this, Spring Boot may buffer or drop logs before the JVM exits.
-->
<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %5level [%thread] %logger{36} - %msg%n</pattern>
    </encoder>
    <!-- Write to System.out, not System.err -->
    <target>System.out</target>
  </appender>

  <!-- Flush immediately — critical for crash diagnostics in containers -->
  <appender name="ASYNC_STDOUT" class="ch.qos.logback.classic.AsyncAppender">
    <queueSize>512</queueSize>
    <neverBlock>false</neverBlock>
    <immediateFlush>true</immediateFlush>
    <appender-ref ref="STDOUT"/>
  </appender>

  <!-- Always show startup errors regardless of profile -->
  <logger name="org.springframework.boot" level="INFO"/>
  <logger name="org.springframework.boot.autoconfigure" level="INFO"/>
  <logger name="org.flywaydb" level="INFO"/>
  <logger name="com.zaxxer.hikari" level="INFO"/>
  <logger name="com.edgro" level="INFO"/>

  <root level="ERROR">
    <appender-ref ref="ASYNC_STDOUT"/>
  </root>
</configuration>
